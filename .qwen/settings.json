{
  "permissions": {
    "defaultMode": "yolo",
    "allow": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh *)",
      "Bash(gh api *)",
      "Bash(cat)",
      "Bash(int *)",
      "Bash(auto *)",
      "Bash(\"{}\", *)",
      "Bash(return *)",
      "Bash(})",
      "Bash(eof)",
      "Bash(g++ *)",
      "Bash(git *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "WebSearch"
    ]
  },
  "general": {
    "language": "ru"
  },
  "context": {
    "fileName": [
      "QWEN.md",
      "RULES.md",
      "DEPLOY.md",
      "CONTRIBUTING.md"
    ]
  },
  "hooks": {
    "onCommit": {
      "command": "echo 'Создаю Pull Request с темой подробным описанием изменений на русском языке'",
      "description": "Автоматическое создание через gh api и JSON: PR с темой и подробным описанием на русском языке после коммита"
    }
  },
  "$version": 3
}